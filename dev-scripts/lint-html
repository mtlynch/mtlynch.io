#!/usr/bin/env bash

# Echo commands to console.
set -x
# Exit on first failing command.
set -e
# Exit on unset variable.
set -u

readonly BUILD_DIR="public"
readonly TEST_DIR="$(mktemp --directory)"
readonly TARGET_BRANCH="master"

lychee_args=()
for arg in "$@"; do
  case "${arg}" in
    --quick)
      lychee_args+=("--offline")
      ;;
    --verbose)
      lychee_args+=("--verbose")
      ;;
    *)
      echo "Unknown argument: ${arg}" >&2
      exit 1
      ;;
  esac
done

function cleanup {
  rm --recursive --force "${TEST_DIR}"
}
trap cleanup EXIT

function add_target {
  local target="$1"

  for existing_target in "${lychee_targets[@]}"; do
    if [[ "${existing_target}" == "${target}" ]]; then
      return
    fi
  done

  lychee_targets+=("${target}")
}

function content_file_to_public_html {
  local content_file="$1"
  local output_path=""
  local url=""

  url="$(grep --max-count=1 '^url: ' "${content_file}" | cut --delimiter=' ' --fields=2- || true)"
  if [[ -n "${url}" ]]; then
    url="${url#/}"
    url="${url%/}"
    output_path="${TEST_DIR}/${url}/index.html"
  elif [[ "${content_file}" == content/posts/*/index.md ]]; then
    output_path="${TEST_DIR}/${content_file#content/posts/}"
    output_path="${output_path%/index.md}/index.html"
  elif [[ "${content_file}" == content/*/_index.md ]]; then
    output_path="${TEST_DIR}/${content_file#content/}"
    output_path="${output_path%/_index.md}/index.html"
  elif [[ "${content_file}" == content/*/index.md ]]; then
    output_path="${TEST_DIR}/${content_file#content/}"
    output_path="${output_path%/index.md}/index.html"
  elif [[ "${content_file}" == content/*.md ]]; then
    output_path="${TEST_DIR}/${content_file#content/}"
    output_path="${output_path%.md}/index.html"
  elif [[ "${content_file}" == content/* ]]; then
    return
  fi

  if [[ -n "${output_path}" && -f "${output_path}" ]]; then
    add_target "${output_path}"
  elif [[ -n "${url}" && -f "${TEST_DIR}/${url}.html" ]]; then
    add_target "${TEST_DIR}/${url}.html"
  else
    echo "No generated HTML found for changed content file: ${content_file}" >&2
  fi
}

function add_changed_targets {
  local changed_file=""

  mapfile -t changed_files < <(git diff --name-only --diff-filter=ACMRT "origin/${TARGET_BRANCH}...HEAD")

  if [[ "${#changed_files[@]}" -eq 0 ]]; then
    return
  fi

  for changed_file in "${changed_files[@]}"; do
    case "${changed_file}" in
      content/*.md|content/**/*.md)
        content_file_to_public_html "${changed_file}"
        ;;
      *.md|*.html|*.htm)
        if [[ -f "${changed_file}" ]]; then
          add_target "${changed_file}"
        fi
        ;;
      *)
        ;;
    esac
  done
}

cp --archive "${BUILD_DIR}/." "${TEST_DIR}/"

rm --force \
  "${TEST_DIR}/collect-debt/full-emails/index.html" \
  "${TEST_DIR}/notes/archivebox/reddit-singlefile.html"

# Check same-site absolute URLs against the local build, not production.
find "${TEST_DIR}" -type f -name "*.html" -print0 | \
  xargs --null --no-run-if-empty sed --in-place 's|https://mtlynch\.io/|/|g'

lychee_targets=()
if [[ "${CIRCLE_BRANCH:-}" == "${TARGET_BRANCH}" ]]; then
  lychee_targets=("${TEST_DIR}/**/*.html")
elif git rev-parse --verify --quiet "origin/${TARGET_BRANCH}" > /dev/null; then
  add_changed_targets
else
  echo "Unable to find origin/${TARGET_BRANCH}; checking all generated HTML" >&2
  lychee_targets=("${TEST_DIR}/**/*.html")
fi

if [[ "${#lychee_targets[@]}" -eq 0 ]]; then
  echo "No Markdown or HTML files changed compared to ${TARGET_BRANCH}; skipping lychee"
  exit 0
fi

printf 'Checking links in files changed relative to %s:\n' "${TARGET_BRANCH}"
printf '  %s\n' "${lychee_targets[@]}"

lychee \
  --config lychee.toml \
  --root-dir "${TEST_DIR}" \
  "${lychee_args[@]}" \
  "${lychee_targets[@]}"
