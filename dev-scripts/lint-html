#!/usr/bin/env bash

# Echo commands to console.
set -x
# Exit on first failing command.
set -e
# Exit on unset variable.
set -u

readonly BASE_URL="https://mtlynch.io/"
readonly TARGET_BRANCH="master"
readonly SELF_LINK_PATTERN="^https://mtlynch\\.io/"

lychee_args=()
for arg in "$@"; do
  case "${arg}" in
    --quick)
      lychee_args+=("--offline")
      ;;
    --verbose)
      lychee_args+=("--verbose")
      ;;
    *)
      echo "Unknown argument: ${arg}" >&2
      exit 1
      ;;
  esac
done

function add_target {
  local target="$1"

  for existing_target in "${markdown_targets[@]}"; do
    if [[ "${existing_target}" == "${target}" ]]; then
      return
    fi
  done

  markdown_targets+=("${target}")
}

function add_all_markdown_targets {
  local markdown_file=""

  mapfile -t markdown_files < <(git ls-files "*.md")

  for markdown_file in "${markdown_files[@]}"; do
    add_target "${markdown_file}"
  done
}

function add_changed_targets {
  local changed_file=""

  mapfile -t changed_files < <(git diff --name-only --diff-filter=ACMRT "origin/${TARGET_BRANCH}...HEAD" -- "*.md")

  if [[ "${#changed_files[@]}" -eq 0 ]]; then
    return
  fi

  for changed_file in "${changed_files[@]}"; do
    if [[ -f "${changed_file}" ]]; then
      add_target "${changed_file}"
    fi
  done
}

markdown_targets=()
if [[ "${CIRCLE_BRANCH:-}" == "${TARGET_BRANCH}" ]]; then
  add_all_markdown_targets
elif git rev-parse --verify --quiet "origin/${TARGET_BRANCH}" > /dev/null; then
  add_changed_targets
else
  echo "Unable to find origin/${TARGET_BRANCH}; checking all Markdown files" >&2
  add_all_markdown_targets
fi

if [[ "${#markdown_targets[@]}" -eq 0 ]]; then
  echo "No Markdown files changed compared to ${TARGET_BRANCH}; skipping lychee"
  exit 0
fi

printf 'Checking links in Markdown files changed relative to %s:\n' "${TARGET_BRANCH}"
printf '  %s\n' "${markdown_targets[@]}"

lychee \
  --config lychee.toml \
  --base-url "${BASE_URL}" \
  --exclude "${SELF_LINK_PATTERN}" \
  "${lychee_args[@]}" \
  "${markdown_targets[@]}"
